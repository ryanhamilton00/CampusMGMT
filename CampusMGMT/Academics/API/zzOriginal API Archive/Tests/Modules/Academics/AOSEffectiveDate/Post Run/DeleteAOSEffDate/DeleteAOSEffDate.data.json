				"RequestMethod": "POST",
				"RequestUrl": "/api/commands/Academics/AreaOfStudy/Get",
				"RequestBody": {},
				"ResponseStatus": 200,
				"ResponseTimeMs": 5000,
				"ResponseBody": {}
			},
			{
				"RequestId": "f04fda8a-dd82-4875-bae1-d34978ab3378",
				"TypeDescription": "Change Name AOS -- Due to Bug that will not allow you to delete AOS once it is associated with PV",
