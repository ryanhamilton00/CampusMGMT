							"    });",
							"} catch(e) { ",
							"    pm.test(\"Load framework - eval\", function() { pm.expect.fail() });",
							"}",
							"",
							"// Resolve global macros",
							"apiUtility.resolveMacros(data.Globals);",
							"",
							"// Read the data file globals section, and setup postman globals.",
							"for(var p in data.Globals) {",
							"  // If Globals own property, set global variable",
							"  if(data.Globals.hasOwnProperty(p)) { ",
							"    var gName = \"g\" + p;",
							"    pm.globals.set(gName, data.Globals[p]);",
							"    //console.log('setting global ' + gName);",
							"  }",
							"}",
							"",
							"// Save data file globals in postman global for chaining purposes.",
							"if(Object.entries(data.Globals).length > 0) {",
							"    let str = \"dataGlobals\";",
							"    apiUtility.globalStoreWrite(str, data.Globals); ",
							"}",
							"",
							"// Validate chain and Api configuration.",
							"let validationStatus = apiUtility.validateChain(data.Globals, data.Apis, chainDefinitionArray);",
							"if(!validationStatus.isValid) {",
							"    let FailFunction = function() { pm.expect.fail() };",
							"    for(let index = 0; index < validationStatus.msgs.length; ++ index) {",
							"        pm.test(\"Chain validation - \" + validationStatus.msgs[index], FailFunction);",
							"    }",
							"}",
							"",
							"// Merge data file API section with chain definition, and setup postman global",
							"if(validationStatus.isValid) {",
							"    let apis  = {};",
							"    for(let index = 0; index < data.Apis.length; ++index) {",
							"        apis[data.Apis[index].RequestId] = data.Apis[index];",
							"    }",
							"    for(let index = 0; index < chainDefinitionArray.length; ++index) {",
							"        apis[chainDefinitionArray[index].RequestId].RequestUrl = chainDefinitionArray[index].RequestUrl;",
							"        apis[chainDefinitionArray[index].RequestId].ChainSource = chainDefinitionArray[index].ChainSource;",
							"        apis[chainDefinitionArray[index].RequestId].Chain = chainDefinitionArray[index].Chain;",
							"        apis[chainDefinitionArray[index].RequestId].Index = index;",
							"    }",
							"    pm.globals.set(\"gApis\", apis);",
							"    //console.log(pm.globals.get(\"gApis\"));",
							"}",
							"",
							"// If chainging is not valid end the collection.",
							"if(!validationStatus.isValid) {",
							"    console.log(\"Chaining is invalid, terminating the test collection\");",
							"    for(let index = 0; index < validationStatus.msgs.length; ++ index) {",
							"        console.log(\"Chain validation - \" + validationStatus.msgs[index]);",
							"    }",
							"    postman.setNextRequest(null);",
							"}",
							"/*****************END DO NOT MODIFY THIS CODE*******************/",
							"",
							"console.log(\"--------------------------------------------------------------------------------------\");",
