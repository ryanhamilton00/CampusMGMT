		{
			"name": "Create",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"id": "9dd23b93-a140-49ae-9a05-b8fee75b494e",
						"type": "text/javascript",
						"exec": [
							"// Load CMC utility code",
							"eval(postman.getGlobalVariable(\"gCmcUtility\"));",
							"",
							"// This is the first request in the collection, clear the global variables",
							"// used in the CRUD collection.   Do not do a clear all globals using pm.globals.clear",
							"// because that will remove the common code global variable gCmcUtility.",
							"pm.globals.unset('gAuthHeaderKey');",
							"pm.globals.unset('gAuthHeaderValue');",
							"pm.globals.unset('gUrl');",
							"pm.globals.unset('gId');",
							"pm.globals.unset('gRowVersion');",
							"pm.globals.unset('gCreateRequestBody');",
							"pm.globals.unset('gCreateResponseBody');",
							"pm.globals.unset('gSaveRequestBody');",
							"pm.globals.unset('gSaveResponseBody');",
							"pm.globals.unset('gGetRequestBody');",
							"pm.globals.unset('gGetResponseBody');",
							"",
							"// Make authorization header using basic auth or API key settings in the data file.",
							"// If data file does not autornization info, use environment variable if available.",
							"var hdr = cmcUtility.makeAuthorization(data.dUser, data.dPassword, data.dApiKey, pm.environment.get('envAuthUser'), pm.environment.get('envAuthPassword'));",
							"pm.globals.set('gAuthHeaderKey', hdr.key);",
							"pm.globals.set('gAuthHeaderValue', hdr.value);",
							"//console.log(pm.globals.get('gAuthHeaderKey'));",
							"//console.log(pm.globals.get('gAuthHeaderValue'));",
							"",
							"// Make URL",
							"pm.globals.set('gUrl', cmcUtility.makeEntityOperationUrl(\"https\", pm.environment.get('envWebHost'), data.dEntityUrl, 'create'));",
							"//console.log(pm.globals.get('gUrl'));",
							"",
							"// Make request body.",
							"pm.globals.set('gCreateRequestBody', cmcUtility.makeRequestBody(data.dCreateRequest));",
							"//console.log(pm.globals.get('gCreateRequestBody'));",
							"",
							""
						]
					}
				},
				{
					"listen": "test",
					"script": {
						"id": "fff156e8-3fcb-40be-8ebb-33f8598933c4",
						"type": "text/javascript",
						"exec": [
							"// Load CMC utility code",
							"eval(postman.getGlobalVariable(\"gCmcUtility\"));",
							"",
							"// Tests",
							"pm.test(\"Verify response status is \" + data.dCreateResponseStatus, function() {",
							"    pm.expect(pm.response.code).to.equal(data.dCreateResponseStatus);",
							"});",
							"pm.test(\"Verify response time is below \" + data.dCreateResponseTime, function() {",
							"    pm.expect(pm.response.responseTime).to.be.below(data.dCreateResponseTime);",
							"});",
							"pm.test(\"Verify response body matches expected response\", function() {",
							"    pm.expect(cmcUtility.verifyResponse(data.dCreateResponse,pm.response.json())).to.be.true;",
							"});",
							"",
							"// If status is OK do chaining, else terminate workflow",
							"if(pm.response.code === 200) {",
							"    pm.globals.set('gCreateResponseBody', pm.response.json());",
							"    //console.log(pm.globals.get('gCreateResponseBody'));",
							"} else {",
							"    postman.setNextRequest(null);",
							"}"
						]
					}
				}
			],
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "POST",
