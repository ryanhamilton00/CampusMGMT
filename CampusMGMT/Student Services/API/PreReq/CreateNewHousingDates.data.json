        "ResponseTimeMs": 5000,
        "ResponseBody": {}
      },
      {
        "RequestId": "9afc606b-242f-4182-80a1-0bda4b13dc63",
        "RequestMethod": "GET",
        "RequestUrl": "/ds/campusnexus/HousingDates?$expand=CampusGroup($select=Id;$expand=CampusList($select=Id;$expand=Campus($select=Id,Name)))&$filter=Id eq {{gHousingDateId}}",
        "RequestBody": null,
        "ResponseStatus": 200,
        "ResponseTimeMs": 5000,
        "ResponseBody": "{\"value\":[]}"
      }
    ]
  }
