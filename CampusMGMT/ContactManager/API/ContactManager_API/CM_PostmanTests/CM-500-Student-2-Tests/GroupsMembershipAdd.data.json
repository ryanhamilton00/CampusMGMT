[{
	"Type": "AdvancedDataFile",
	"Version": "2.0",
	"TestDescription": "This API will add a Group to a student in Contact Manager",
	"Globals": {
		"StudentSsn": "111-33-0066"
	},
	"Apis": [{
			"RequestId": "00000000-0000-0000-0000-000000000000",
			"RequestMethod": "GET",
			"RequestUrl": "/ds/campusnexus/Staff/CampusNexus.GetCurrentLoggedInUserStaff?$select=Id,DefaultSyCampusId,PersonId,CampusGroupId",
			"RequestBody": null,
			"ResponseStatus": 200,
			"ResponseTimeMs": 10000,
			"ResponseBody": "{\"value\":[]}"
		},
		{
			"RequestId": "00000000-0000-0000-0000-000000000001",
			"RequestMethod": "GET",
			"RequestUrl": "/ds/campusnexus/Students?$filter=Ssn eq '{{gStudentSsn}}'",
			"RequestBody": null,
			"ResponseStatus": 200,
			"ResponseTimeMs": 10000,
			"ResponseBody": "{\"value\":[]}"
		},
		{
			"RequestId": "00000000-0000-0000-0000-000000000002",
			"RequestMethod": "GET",
			"RequestUrl": "/ds/campusnexus/StudentGroupMembers/CampusNexus.GetIsirVerificationGroupForStudentCampus(studentId={{gStudentId}})",
			"RequestBody": null,
			"ResponseStatus": 200,
			"ResponseTimeMs": 10000,
			"ResponseBody": "{\"value\":[]}"
		},
		{
			"RequestId": "00000000-0000-0000-0000-000000000003",
			"RequestMethod": "GET",
			"RequestUrl": "/ds/campusnexus/StudentGroups/CampusNexus.GetStudentGroupsBasedOnStaff(staffId={{gUserId}},studentId ={{gStudentId}},isStaffAdmin=true,isirVerificationGroupId={{gIsirId}})?&$select=Id,Name,Code,CreatedDateTime&$expand=GroupOwner($select=FullName)&$top=5",
			"RequestBody": null,
			"ResponseStatus": 200,
			"ResponseTimeMs": 10000,
			"ResponseBody": "{\"value\":[]}"
		},
		{
			"RequestId": "00000000-0000-0000-0000-000000000004",
			"RequestMethod": "POST",
			"RequestUrl": "/api/commands/Common/StudentGroupMember/AddStudent",
			"RequestBody": {
				"payload": {
					"StudentId": "{{gStudentId}}",
					"ChangeGroupTypeToManual": false,
					"IsGroupSameAsIsirVerificationStudentGroup": false
				}},
			"ResponseStatus": 200,
			"ResponseTimeMs": 5000,
			"ResponseBody": {"payload": {}}
		},		
		{
			"RequestId": "00000000-0000-0000-0000-000000000005",
			"RequestMethod": "POST",
			"RequestUrl": "/api/commands/Common/Student/get",
			"RequestBody": {
				"payload": {
					"id": "{{gStudentId}}"
				}},
			"ResponseStatus": 200,
			"ResponseTimeMs": 5000,
			"ResponseBody": {"payload": {}}
		}
	]
}]