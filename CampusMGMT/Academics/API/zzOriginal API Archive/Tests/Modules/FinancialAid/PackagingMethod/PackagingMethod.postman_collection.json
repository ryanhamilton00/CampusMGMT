		{
			"name": "Save",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"id": "d39de719-285f-47ae-951e-8fd4db75a181",
						"type": "text/javascript",
						"exec": [
							"// Load CMC utility code",
							"eval(postman.getGlobalVariable(\"gCmcUtility\"));",
							"var packMethodDetails=[];",
							"var packMethodid=[];",
							"",
							"var packDetailCamList=[];",
							"var packDetailid=[];",
							"",
							"// Make authorization header using basic auth or API key settings in the data file.",
							"// If data file does not autornization info, use environment variable if available.",
							"var hdr = cmcUtility.makeAuthorization(data.dUser, data.dPassword, data.dApiKey, pm.environment.get('envAuthUser'), pm.environment.get('envAuthPassword'));",
							"pm.globals.set('gAuthHeaderKey', hdr.key);",
							"pm.globals.set('gAuthHeaderValue', hdr.value);",
							"//console.log(pm.globals.get('gAuthHeaderKey'));",
							"//console.log(pm.globals.get('gAuthHeaderValue'));",
							"",
							"// Make URL",
							"pm.globals.set('gUrl', cmcUtility.makeEntityOperationUrl(\"https\", pm.environment.get('envWebHost'), data.dEntityUrl, 'save'));",
							"//console.log(pm.globals.get('gUrl'));",
							"console.log(pm.globals.get('gGetResponseBody'));",
							"var res = pm.globals.get('gGetResponseBody');",
							"",
							"pm.globals.set('PackRowVer',res.payload.data.rowVersion);",
							"pm.globals.set('LengPackDet',res.payload.data.packagingMethodDetails.length);",
							"pm.globals.set('CampusGrpRowVer',res.payload.data.campusGroup.rowVersion);",
							"pm.globals.set('CampusGrpId',res.payload.data.campusGroup.id);",
							"//pm.globals.set('CampusDetLeng',req.payload.data.packagingMethodDetail.CampusGroup.campusList.length);",
							"",
							"console.log(pm.globals.get('PackRowVer'));",
							"console.log(pm.globals.get('LengPackDet'));",
							"",
							"for(i=0;i<pm.globals.get('LengPackDet');i++)",
							"{",
							"    console.log(\"inside for loop\");",
							"    packMethodDetails[i]=res.payload.data.packagingMethodDetails[i].rowVersion;",
							"    packMethodid[i]=res.payload.data.packagingMethodDetails[i].packagingMethodId;",
							"    ",
							"}",
							"",
							"",
							"for(i=0;i<pm.globals.get('CampusDetLeng');i++)",
							"{",
							"        console.log(\"inside for loop 2\");",
							"    packDetailCamList[i]=res.payload.data.campusGroup.campusList[i].rowVersion;",
							"    packDetailid[i]=res.payload.data.campusGroup.campusList[i].id;",
							"    ",
							"}",
							"",
							"//get the row version",
							"// Make request body.",
							"var req = JSON.parse(cmcUtility.makeRequestBody(data.dSaveRequest));",
							"req.payload.id = pm.globals.get('gId');",
							"req.payload.rowVersion = pm.globals.get('PackRowVer');",
							"req.payload.campusGroup.rowVersion = pm.globals.get('CampusGrpRowVer');",
							"req.payload.campusGroup.id = pm.globals.get('CampusGrpId');",
							"",
							"for(i=0;i<pm.globals.get('LengPackDet');i++)",
							"{",
							"    console.log(\"inside setting loop\");",
							"  req.payload.packagingMethodDetails[i].rowVersion =   packMethodDetails[i];",
							"  req.payload.packagingMethodDetails[i].packagingMethodId =  packMethodid[i];",
							"    ",
							"}",
							"",
							"",
							"for(i=0;i<pm.globals.get('CampusDetLeng');i++)",
							"{",
							"   req.payload.campusGroup.campusList[i].rowVersion = packDetailCamList[i];",
							"    req.payload.campusGroup.campusList[i].id=packDetailid[i];",
							"    ",
							"}",
							"",
							"",
							"",
							"pm.globals.set('gSaveRequestBody', JSON.stringify(req));",
							"//console.log(pm.globals.get('gSaveRequestBody'));",
							"",
							""
						]
					}
				},
				{
					"listen": "test",
					"script": {
						"id": "7ebd0873-4ce7-4868-9ca8-f7672de08d9c",
						"type": "text/javascript",
						"exec": [
							"// Load CMC utility code",
							"eval(postman.getGlobalVariable(\"gCmcUtility\"));",
							"",
							"// Tests",
							"pm.test(\"Verify response status is \" + data.dSaveNewResponseStatus, function() {",
							"    pm.expect(pm.response.code).to.equal(data.dSaveNewResponseStatus);",
							"});",
							"pm.test(\"Verify response time is below \" + data.dSaveNewResponseTime, function() {",
							"    pm.expect(pm.response.responseTime).to.be.below(data.dSaveNewResponseTime);",
							"});",
							"pm.test(\"Verify response body matches expected response\", function() {",
							"    pm.expect(cmcUtility.verifyResponse(data.dSaveResponse,pm.response.json())).to.be.true;",
							"});",
							"",
							"// If status is OK do chaining, else terminate workflow",
							"if(pm.response.code === 200) {",
							"    var rb = pm.response.json();",
							"    pm.globals.set('gId', rb.payload.data.id);",
							"    pm.globals.set('gRowVersion', rb.payload.data.rowVersion);",
							"    pm.globals.set('gSaveResponseBody', rb);",
							"    //console.log(pm.globals.get('gId'));",
							"    //console.log(pm.globals.get('gRowVersion'));",
							"    //console.log(pm.globals.get('gSaveNewResponseBody'));",
							"} else {",
							"    postman.setNextRequest(null);",
							"}",
							""
						]
					}
				}
