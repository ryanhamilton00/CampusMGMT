                "RequestBody": null,
                "ResponseStatus": 200,
                "ResponseTimeMs": 10000,
                "ResponseBody": "{\"value\":[]}"
            },
            {
                "RequestId": "00000000-0000-0000-0000-000000000001",
                "RequestMethod": "GET",
                "RequestUrl": "/ds/campusnexus/Students?$filter=Ssn eq '{{gStudentSsn}}'",
                "RequestBody": null,
                "ResponseStatus": 200,
                "ResponseTimeMs": 10000,
                "ResponseBody": "{\"value\":[]}"
            },
            {
                "RequestId": "00000000-0000-0000-0000-000000000003",
                "RequestMethod": "GET",
                "RequestUrl": "/ds/campusnexus/StudentEnrollmentPeriods?$filter=StudentId eq {{gStudentId}}",
