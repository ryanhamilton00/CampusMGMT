							"pm.test(\"Verify response status is \" + data.dCloseResponseStatus, function() {",
							"    pm.expect(pm.response.code).to.equal(data.dCloseResponseStatus);",
							"});",
							"pm.test(\"Verify response time is below \" + data.dCloseResponseTime, function() {",
