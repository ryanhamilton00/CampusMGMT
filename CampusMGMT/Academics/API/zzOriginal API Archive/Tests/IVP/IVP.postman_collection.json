	"item": [
		{
			"_postman_id": "a601f3ae-4e72-4ab7-a13e-8b87487873ba",
			"name": "Get Student id",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "f04a35f0-d96d-4a87-98a8-7ede8df4351e",
						"type": "text/javascript",
						"exec": [
							"// Test to make sure that ",
							"pm.test(\"Get Student id\", function() {",
							"    pm.response.to.be.ok;",
							"})",
							"",
							"// If student id is available set it as a global var",
							"// so it can be used to retrieve data.",
							"var rb = pm.response.json();",
							"if(rb.value.length > 0) {",
							"    pm.globals.set('gStudentId', rb.value[0].Id);",
							"} ",
							""
						]
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"id": "c4c5c70d-6da2-41a9-82e8-d8bb53e65802",
						"type": "text/javascript",
						"exec": [
							"//console.log(pm.environment.get('envAuthHeaderKey'));",
							"//console.log(pm.environment.get('envAuthHeaderValue'));",
							""
						]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "{{envAuthHeaderKey}}",
						"value": "{{envAuthHeaderValue}}"
					},
					{
						"key": "ContentType",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"payload\":{\n    \"degreeProgressAuditRequestor\":1,\n    \"studentId\":0,\n    \"studentEnrollmentPeriodId\":0,\n    \"isHypothetical\":false\n  }\n}"
				},
				"url": {
					"raw": "http://{{envWebHost}}/ds/campusnexus/Students?$select=Id&$top=1",
					"protocol": "http",
					"host": [
						"{{envWebHost}}"
					],
					"path": [
						"ds",
						"campusnexus",
						"Students"
					],
					"query": [
						{
							"key": "$select",
							"value": "Id"
						},
						{
							"key": "$top",
							"value": "1"
						}
					]
				}
			},
			"response": []
		},
		{
			"_postman_id": "401fdabb-704d-4cac-852f-26ba3a5ddc10",
			"name": "Get Student data",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "238bd3ab-7e14-44a0-a72f-5ccb37b0acff",
						"type": "text/javascript",
						"exec": [
							"pm.test(\"Get Student data\", function() {",
							"    pm.response.to.be.ok;",
							"    // If student id was set, compare it to response value.",
							"    if(pm.globals.has('gStudentId')) {",
							"        pm.expect(pm.response.json().payload.data.id).to.be.equal(pm.globals.get('gStudentId'));",
							"    }",
							"});",
							""
						]
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"id": "6de25ced-4406-4f66-b676-5f0d4bb6bb74",
						"type": "text/javascript",
						"exec": [
							"// If we have a student id, use it in the request body. ",
							"// Else send an empty payload.",
							"if(pm.globals.has('gStudentId')) {",
							"    pm.globals.set('getStudentDataRequestBody', '{ \"payload\": { \"id\" : ' + pm.globals.get('gStudentId') + ' }}' );     ",
							"} else {",
							"    pm.globals.set('getStudentDataRequestBody', '{ \"payload\": {}}');",
							"}",
							""
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "{{envAuthHeaderKey}}",
						"value": "{{envAuthHeaderValue}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{{getStudentDataRequestBody}}"
				},
				"url": {
					"raw": "http://{{envWebHost}}/api/commands/Common/Student/get",
					"protocol": "http",
					"host": [
						"{{envWebHost}}"
					],
					"path": [
						"api",
						"commands",
						"Common",
						"Student",
						"get"
					]
				}
			},
			"response": []
		},
