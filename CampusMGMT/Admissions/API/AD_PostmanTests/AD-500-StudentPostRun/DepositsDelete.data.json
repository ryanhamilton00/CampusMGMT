          {
            "RequestId": "00000000-0000-0000-0000-000000000002",
            "RequestMethod": "GET",
            "RequestUrl": "/ds/campusnexus/StudentDepositDetails/CampusNexus.GetStudentDepositDetails(studentId={{gStudentId}},getHousingDeposits=0)?&$orderby=DepositReceivedDate desc,ReceiptNumber&$count=true&$filter=StudentEnrollmentPeriodId eq {{gEnrollId}}",
            "RequestBody": null,
            "ResponseStatus": 200,
            "ResponseTimeMs": 10000,
            "ResponseBody": "{\"value\":[]}"
