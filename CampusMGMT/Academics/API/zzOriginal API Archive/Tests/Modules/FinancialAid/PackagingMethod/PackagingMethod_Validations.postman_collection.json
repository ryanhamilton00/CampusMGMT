							"//console.log(pm.globals.get('gUrl'));",
							"",
							"// Make request body.",
							"pm.globals.set('gSaveRequestBody', cmcUtility.makeRequestBody(data.dSaveNewRequest));",
							"//console.log(pm.globals.get('gSaveRequestBody'));",
