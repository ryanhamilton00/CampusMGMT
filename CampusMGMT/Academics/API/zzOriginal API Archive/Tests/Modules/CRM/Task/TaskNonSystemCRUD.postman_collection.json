							"pm.globals.set('gAuthHeaderValue', hdr.value);",
							"//console.log(pm.globals.get('gAuthHeaderKey'));",
							"//console.log(pm.globals.get('gAuthHeaderValue'));",
							"",
							"// Make URL",
							"pm.globals.set('gUrl', cmcUtility.makeEntityOperationUrl(pm.environment.get('envWebHost'), data.dEntityUrl, 'saveNew'));",
							"//console.log(pm.globals.get('gUrl'));",
							"",
							"// Create request from CREATE API call, and merge with data file SaveNew request",
							"var requestFromCreate = {};",
							"requestFromCreate.payload = pm.globals.get('gCreateResponseBody').payload.data;",
							"//console.log(\"requestFromCreate: \" + JSON.stringify(requestFromCreate));",
							"",
							"var request = cmcUtility.mergeRequestBody(cmcUtility.mergeRequestBody(requestFromCreate,data.dSaveNewRequest));",
							"request.payload.assignedToStaffId = pm.globals.get(\"gLoggedInUserId\");",
							"request.payload.createdByStaffId = pm.globals.get(\"gLoggedInUserId\"); ",
							"//console.log(\"request: \" + JSON.stringify(request));",
							"pm.globals.set('gSaveRequestBody', JSON.stringify(request));",
							"",
							""
						]
					}
