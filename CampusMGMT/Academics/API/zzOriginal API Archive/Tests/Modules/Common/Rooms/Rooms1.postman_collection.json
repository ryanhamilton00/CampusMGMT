      "event": [
        {
          "listen": "prerequest",
          "script": {
            "id": "6af004cf-f8a1-43fa-bbba-ff47c9d5bba8",
            "type": "text/javascript",
            "exec": [
              "// Load CMC utility code",
              "eval(postman.getGlobalVariable(\"gCmcUtility\"));",
              "let API = data.Apis[pm.globals.get('gIndex')];",
              "",
              "//Make authorization header using basic auth or API key settings in the data file.",
              "//If data file does not autornization info, use environment variable if available.",
              "var hdr = cmcUtility.makeAuthorization(API.User, API.Password, API.ApiKey, pm.environment.get('envAuthUser'), pm.environment.get('envAuthPassword'));",
              "pm.globals.set('gAuthHeaderKey', hdr.key);",
              "pm.globals.set('gAuthHeaderValue', hdr.value);",
              "// console.log(pm.globals.get('gAuthHeaderKey'));",
              "// console.log(pm.globals.get('gAuthHeaderValue'));",
              "",
              "// Make URL",
              "pm.globals.set('gUrl', cmcUtility.makeUrl( API.Scheme,pm.environment.get('envWebHost'), API.RequestUrl));",
              "//console.log(pm.globals.get('gUrl'));",
              "",
              "// Make request body.",
              "// Make request body.",
              "var request = {};",
              "cmcUtility.setChainProps(API.Chain,request);",
              "var req = cmcUtility.mergeRequestBody(request,API.RequestBody);",
              "",
              "pm.globals.set('gGetRequestBody', JSON.stringify(req));",
              "",
              ""
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "id": "54a71a1b-229c-4859-8a15-3c5967e81cfc",
            "type": "text/javascript",
            "exec": [
              "// Load CMC utility code",
              "eval(postman.getGlobalVariable(\"gCmcUtility\"));",
              "",
              "let API = data.Apis[pm.globals.get('gIndex')];",
              "// Tests",
              "pm.test(\"Verify response status is \" + API.ResponseStatus, function() {",
              "    pm.expect(pm.response.code).to.equal(API.ResponseStatus);",
              "});",
              "pm.test(\"Verify response time is below \" + API.ResponseTimeMs, function() {",
              "    pm.expect(pm.response.responseTime).to.be.below(API.ResponseTimeMs);",
              "});",
              "pm.test(\"Verify response body matches expected response\", function() {",
              "     var actualresponse=JSON.parse(responseBody);",
              "    pm.expect(cmcUtility.verifyResponse(API.ResponseBody,pm.response.json())).to.be.true;",
              "});",
              "//console.log(pm.globals.get('gIndex'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
