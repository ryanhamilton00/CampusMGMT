		{
			"_postman_id": "a43b7200-48ca-40dc-b687-8f399eaf2039",
			"name": "Verify Regulatory Campus Link configuration",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "d4bf0018-0fbb-4170-9a73-4ad6399ec91d",
						"type": "text/javascript",
						"exec": [
							"pm.test(\"Verify Regulatory Campus Link configuration\", function() {",
							"    // There is a configuration problem if we get 500 error, and",
							"    // the error message begins with \"there is no endpoint listening at \"",
							"    var isFailed = false;",
							"    if(pm.response.code === 500) {",
							"        var body = JSON.parse(responseBody);",
							"        if(body.error && body.error.innererror && body.error.innererror.message){",
							"            var noEndpointMsg = 'There was no endpoint listening at ';",
							"            isFailed = body.error.innererror.message.indexOf(noEndpointMsg) === 0;",
							"        }",
							"    }",
							"    pm.expect(isFailed).to.equal(false);",
							"})",
							""
						]
					}
				},
				{
					"listen": "prerequest",
					"script": {
