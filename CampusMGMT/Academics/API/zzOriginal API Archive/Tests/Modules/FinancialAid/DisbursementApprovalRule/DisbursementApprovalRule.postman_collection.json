		{
			"name": "Save",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"id": "389ad2a8-0116-458b-b646-c9aeb9bfc784",
						"type": "text/javascript",
						"exec": [
							"// Load CMC utility code",
							"eval(postman.getGlobalVariable(\"gCmcUtility\"));",
							"   var DocumentApprovalId = [];",
							"          var DocumentRowVersion = [];",
							"          ",
							"           var schoolApprovalId = [];",
							"          var schoolRowVersion = [];",
							"",
							"// Make authorization header using basic auth or API key settings in the data file.",
							"// If data file does not autornization info, use environment variable if available.",
							"var hdr = cmcUtility.makeAuthorization(data.dUser, data.dPassword, data.dApiKey, pm.environment.get('envAuthUser'), pm.environment.get('envAuthPassword'));",
							"pm.globals.set('gAuthHeaderKey', hdr.key);",
							"pm.globals.set('gAuthHeaderValue', hdr.value);",
							"",
							"",
							"// Make URL",
							"pm.globals.set('gUrl', cmcUtility.makeEntityOperationUrl(\"https\", pm.environment.get('envWebHost'), data.dEntityUrl, 'save'));",
							"",
							"",
							"// Getting the DAC id and Rowversion for each entity",
							"var getresbody=pm.globals.get('gGetResponseBody');",
							"var req = JSON.parse(cmcUtility.makeRequestBody(data.dSaveRequest));",
							"req.payload.id = pm.globals.get('DacId');",
							"req.payload.rowVersion= pm.globals.get('DacRowVersion');",
							"",
							"req.payload.disbursementApprovalRuleMultipleDisbursement[0].id = pm.globals.get('MultipleDacId');",
							"req.payload.disbursementApprovalRuleMultipleDisbursement[0].rowVersion= pm.globals.get('MultipleDacRowVersion');",
							"",
							"//Document entity id and rowversion",
							"",
							" pm.globals.set('len',getresbody.payload.data.documentTypes.length);",
							"var i;",
							"     ",
							"for (i = 0; i < pm.globals.get('len'); i++) { ",
							"    DocumentApprovalId[i]=getresbody.payload.data.documentTypes[i].disbursementApprovalRuleId;",
							"    DocumentRowVersion[i]=getresbody.payload.data.documentTypes[i].rowVersion;",
							"    ",
							"    ",
							"}",
							"",
							"//Overriding the requests id and rowversion ",
							"",
							"   pm.globals.set('doclen',req.payload.documentTypes.length);",
							"       ",
							"        var i;",
							"        var reqDocumentApprovalId = [];",
							"          var reqDocumentRowVersion = [];",
							"for (i = 0; i < pm.globals.get('len'); i++) { ",
							"    req.payload.documentTypes[i].disbursementApprovalRuleId=DocumentApprovalId[i];",
							"    req.payload.documentTypes[i].rowVersion=DocumentRowVersion[i];",
							"   ",
							"}",
							"//Fetching the rowversion and id of the school status",
							"  ",
							"   pm.globals.set('len',getresbody.payload.data.schoolStatuses.length);",
							"        console.log(pm.globals.get('schoollen'));",
							"        var i;",
							"     ",
							"for (i = 0; i < pm.globals.get('schoollen'); i++) { ",
							"    schoolApprovalId[i]=getresbody.payload.data.schoolStatuses[i].disbursementApprovalRuleId;",
							"    schoolRowVersion[i]=getresbody.payload.data.schoolStatuses[i].rowVersion;",
							"    ",
							"    ",
							"}",
							"    ",
							"//Assigning the rowv ersion and id of the delete request",
							"",
							"   pm.globals.set('doclen',req.payload.schoolStatuses.length);",
							"        ",
							"        var i;",
							"        var reqschoolstatusesApprovalId = [];",
							"          var reqschoolstatusRowVersion = [];",
							"for (i = 0; i < pm.globals.get('schoollen'); i++) { ",
							"    req.payload.schoolStatuses[i].disbursementApprovalRuleId=schoolApprovalId[i];",
							"    req.payload.schoolStatuses[i].rowVersion=schoolRowVersion[i];",
							"   ",
							"}",
							"  ",
							"",
							"     ",
							" ",
							"    ",
							"    ",
							"pm.globals.set('gSaveRequestBody', JSON.stringify(req));",
							"//console.log(pm.globals.get('gSaveRequestBody'));",
							"",
							""
						]
					}
				},
